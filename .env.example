# Copie para .env e preencha (nunca commite .env)
# Chave em: https://platform.openai.com/api-keys

OPENAI_API_KEY=
# Opcional (padrão: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# --- Rastreamento (Prisma + Melhor Envio) ---
# Modo 100% sem banco: só consulta pública na API ME (sem Prisma/SQLite/Postgres).
# Com 1: não define DATABASE_URL por defeito; sem rotas /api/rastreio/admin/*; sem webhook ME; polling desligado.
# Credenciais ME via ME_PANEL_ACCESS_TOKEN ou ME_CLIENT_ID+ME_CLIENT_SECRET+ME_REFRESH_TOKEN no .env.
# RASTREIO_SEM_BANCO=1

# SQLite local (padrão quando RASTREIO_SEM_BANCO não está ativo). Produção: postgresql://USER:PASS@HOST:5432/DB
# Arquivo SQLite criado em prisma/dev.db após `npm run db:push`
DATABASE_URL="file:./dev.db"

# OAuth2 Melhor Envio (aplicativo no painel ME) — https://docs.melhorenvio.com.br/
# Produção: https://melhorenvio.com.br ou https://www / https://api conforme doc. Sandbox: https://sandbox.melhorenvio.com.br
ME_API_BASE=https://www.melhorenvio.com.br
# Recomendado pela doc: User-Agent = nome + e-mail de suporte (ou defina ME_USER_AGENT completo).
ME_CONTACT_EMAIL=
# ME_USER_AGENT=

# OAuth — URL de retorno igual à cadastrada no app ME (mesmo valor em Secrets do GitHub ≠ automático no Node).
# Tem de existir no processo que roda server.js (hosting ou .env). Local: http://localhost:3000/oauth/callback
# ME_OAUTH_REDIRECT_URI=https://delicattopersonalizados.com.br/oauth/callback
# Escopos separados por espaço (doc Melhor Envio). Rastreio: shipping-tracking
# ME_OAUTH_SCOPES=shipping-tracking
ME_CLIENT_ID=
ME_CLIENT_SECRET=
# Refresh OAuth. No servidor, quando a ME devolve um refresh novo, o processo usa-o em memória (RASTREIO_SEM_BANCO).
# Entre restarts do Render, mantenha ME_REFRESH_TOKEN atualizado ou refaça OAuth.
ME_REFRESH_TOKEN=
# JWT “Permissões de acesso” no painel ME. Se preenchido, a API usa este token (não precisa de ME_REFRESH_TOKEN para chamar a API).
# O access da API renova em memória conforme expiração do JWT; não confundir com refresh OAuth.
ME_PANEL_ACCESS_TOKEN=

# Webhook (opcional): configure no painel ME apontando para POST /api/rastreio/webhook/melhor-envio
ME_WEBHOOK_SECRET=

# Token longo para painel /rastreios/admin/ (header X-Rastreio-Admin-Token)
RASTREIO_ADMIN_TOKEN=

# Limite consulta pública (por IP / 15 min)
RASTREIO_RATE_MAX=40

# Se 1 ou vazio: sem envio no banco, tenta localizar pelo código na API ME (GET /api/v2/me/orders/search). Use 0 para exigir cadastro local.
# RASTREIO_CONSULTA_ME_SEM_CADASTRO=1

# Polling fallback: minutos entre sincronizações (0 = desligado; mínimo 5 se > 0)
RASTREIO_POLL_MINUTOS=0
